# Copy to .env and fill in secrets. Never commit .env.

# Public URL of the command/control (C2C) web UI
CC_BEARER_URL=https://vtlibai-cc.endeavour.cs.vt.edu

# CAS v2 authentication endpoints
CAS_SERVICE_URL=https://vtlibai-cc.endeavour.cs.vt.edu/api/user/casvalidate
CAS_LOGIN_URL=https://login.vt.edu/profile/cas/login
CAS_SERVICE_VALIDATE_URL=https://login.vt.edu/profile/cas/serviceValidate

# Comma-separated list of accounts with admin privileges on the CC server
ADMIN_ACCOUNTS=

# Bearer token agent pods and external triggers use to call the C2C machine API
CC_BEARER_TOKEN=

# Container registry where images are pushed/pulled
REGISTRY_SERVER=container.cs.vt.edu
REGISTRY_USERNAME=
REGISTRY_PASSWORD=

SANDBOX_CONTAINER_IMAGE=container.cs.vt.edu/gback/registry/opencode-sandbox:latest
CC_CONTAINER_IMAGE=container.cs.vt.edu/gback/registry/agent-supervisor:latest

# Postgres connection (dev default matches c2c/docker-compose.yml)
DATABASE_URL=postgres://c2c:c2c@localhost:5433/c2c

# Secret used to sign session cookies (generate with: openssl rand -base64 32)
SESSION_SECRET=

# Kubernetes access
KUBECONFIG=../endeavour.yaml
K8S_NAMESPACE=vtlib

# Optional: restrict agent pods to labeled nodes, e.g. "vtlib/agents=true"
# (label nodes with: kubectl label node <name> vtlib/agents=true)
#SANDBOX_NODE_SELECTOR=

# In-cluster URL agent pods use to reach the C2C API (falls back to CC_BEARER_URL)
CC_INTERNAL_URL=http://c2c.vtlib.svc.cluster.local:3000

# LLM provider base URL (seeded into the providers table). API keys are
# per user — each user enters theirs on the "API Keys" page.
LLM_API_BASE_URL=https://llm-api.arc.vt.edu/api/v1

# Dev only: skip CAS and log in as this user (ignored when NODE_ENV=production)
#DEV_FAKE_USER=gback
